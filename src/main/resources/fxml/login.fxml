<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="360.0" prefWidth="440.0" styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.icq.gui.client.LoginController">
    <center>
        <VBox alignment="CENTER" maxWidth="320.0" spacing="16.0" styleClass="login-panel">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
            </padding>
            <Label styleClass="brand-title" text="ICQ" />
            <Label styleClass="subtitle" text="Connect to messenger server" />
            <TextField fx:id="serverIpField" promptText="Server IP" />
            <TextField fx:id="usernameField" promptText="Username" />
            <Button fx:id="connectButton" maxWidth="Infinity" onAction="#connect" text="Connect" />
        </VBox>
    </center>
</BorderPane>
