<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1240.0" styleClass="messenger-page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.icq.gui.client.ChatController">
    <left>
        <VBox minWidth="280.0" prefWidth="330.0" spacing="16.0" styleClass="dialog-sidebar">
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="profile-block">
                <StackPane>
                    <ImageView fx:id="ownAvatarView" fitHeight="58.0" fitWidth="58.0" preserveRatio="true" />
                    <Button fx:id="profileEditButton" onAction="#openProfileSettings" styleClass="avatar-edit-button" text="" StackPane.alignment="BOTTOM_RIGHT" />
                </StackPane>
                <VBox spacing="4.0">
                    <Label fx:id="ownNameLabel" styleClass="profile-name" text="User" />
                    <Label fx:id="ownStatusLabel" styleClass="profile-status" text="Online" />
                </VBox>
            </HBox>
            <HBox alignment="CENTER" spacing="10.0" styleClass="sidebar-tabs">
                <Button maxWidth="Infinity" onAction="#showChats" styleClass="tab-button" text="Chats" HBox.hgrow="ALWAYS" />
                <Button maxWidth="Infinity" onAction="#showGroups" styleClass="tab-button" text="Groups" HBox.hgrow="ALWAYS" />
                <Button fx:id="newGroupButton" onAction="#openCreateGroup" styleClass="icon-button" text="+" />
            </HBox>
            <TextField fx:id="searchField" promptText="Search users, groups, messages, files" />
            <StackPane VBox.vgrow="ALWAYS">
                <ListView fx:id="dialogsList" />
                <ListView fx:id="groupsList" visible="false" />
            </StackPane>
        </VBox>
    </left>
    <center>
        <BorderPane minWidth="520.0" styleClass="chat-surface">
            <top>
                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="chat-topbar">
                    <padding>
                        <Insets bottom="16.0" left="22.0" right="22.0" top="16.0" />
                    </padding>
                    <ImageView fx:id="chatAvatarView" fitHeight="46.0" fitWidth="46.0" preserveRatio="true" />
                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                        <Label fx:id="titleLabel" styleClass="chat-title" text="Select a chat" />
                        <Label fx:id="chatStatusLabel" styleClass="chat-subtitle" text="Messenger MAX is ready" />
                    </VBox>
                    <Label fx:id="recordingTimerLabel" styleClass="recording-timer" text="" />
                </HBox>
            </top>
            <center>
                <VBox spacing="6.0" styleClass="message-area">
                    <padding>
                        <Insets bottom="8.0" left="0.0" right="0.0" top="8.0" />
                    </padding>
                    <Label styleClass="date-chip" text="Today" />
                    <ListView fx:id="messagesList" VBox.vgrow="ALWAYS" />
                    <Label fx:id="typingLabel" styleClass="typing-label" text="typing..." />
                </VBox>
            </center>
            <bottom>
                <VBox styleClass="composer-shell">
                    <HBox fx:id="recordingWavesBox" alignment="CENTER_LEFT" spacing="5.0" styleClass="recording-waves" visible="false" managed="false">
                        <Label text="Recording" />
                        <Label styleClass="wave-bar" text="" />
                        <Label styleClass="wave-bar wave-small" text="" />
                        <Label styleClass="wave-bar wave-large" text="" />
                        <Label styleClass="wave-bar" text="" />
                        <Label styleClass="wave-bar wave-small" text="" />
                    </HBox>
                    <HBox alignment="CENTER" spacing="10.0" styleClass="composer">
                        <padding>
                            <Insets bottom="16.0" left="22.0" right="22.0" top="16.0" />
                        </padding>
                        <Button fx:id="attachButton" onAction="#attachFile" styleClass="icon-button" text="" />
                        <Button fx:id="emojiButton" onAction="#insertEmoji" styleClass="icon-button" text="" />
                        <TextField fx:id="messageField" promptText="Write a message..." HBox.hgrow="ALWAYS" />
                        <Button fx:id="voiceButton" onAction="#toggleVoiceRecording" styleClass="icon-button" text="" />
                        <Button fx:id="sendButton" onAction="#sendMessage" text="Send" />
                    </HBox>
                </VBox>
            </bottom>
        </BorderPane>
    </center>
</BorderPane>
