<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="680.0" prefWidth="980.0" styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.icq.gui.client.ChatController">
    <left>
        <VBox prefWidth="240.0" spacing="10.0" styleClass="sidebar">
            <padding>
                <Insets bottom="16.0" left="16.0" right="12.0" top="16.0" />
            </padding>
            <Label styleClass="section-title" text="Online users" />
            <ListView fx:id="usersList" VBox.vgrow="ALWAYS" />
        </VBox>
    </left>
    <center>
        <BorderPane styleClass="chat-panel">
            <top>
                <HBox alignment="CENTER_LEFT" styleClass="chat-header">
                    <padding>
                        <Insets bottom="14.0" left="18.0" right="18.0" top="14.0" />
                    </padding>
                    <Label fx:id="titleLabel" styleClass="section-title" text="Select a user" />
                </HBox>
            </top>
            <center>
                <ListView fx:id="messagesList" styleClass="messages-list" />
            </center>
            <bottom>
                <HBox spacing="10.0" styleClass="message-input">
                    <padding>
                        <Insets bottom="16.0" left="18.0" right="18.0" top="14.0" />
                    </padding>
                    <TextField fx:id="messageField" promptText="Write a message..." HBox.hgrow="ALWAYS" />
                    <Button onAction="#sendMessage" text="Send" />
                </HBox>
            </bottom>
        </BorderPane>
    </center>
</BorderPane>
