<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" styleClass="page" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.icq.gui.server.ServerController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="server-header">
            <padding>
                <Insets bottom="14.0" left="18.0" right="18.0" top="14.0" />
            </padding>
            <Label styleClass="brand-small" text="ICQ Server" />
            <Label fx:id="statusLabel" styleClass="subtitle" text="Starting..." HBox.hgrow="ALWAYS" />
            <Button onAction="#stopServer" text="Stop" />
        </HBox>
    </top>
    <center>
        <HBox spacing="16.0">
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
            </padding>
            <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                <Label styleClass="section-title" text="Event log" />
                <ListView fx:id="eventsList" prefHeight="220.0" VBox.vgrow="ALWAYS" />
                <Label styleClass="section-title" text="All messages" />
                <ListView fx:id="messagesList" prefHeight="320.0" VBox.vgrow="ALWAYS" />
            </VBox>
            <VBox prefWidth="320.0" spacing="10.0">
                <Label styleClass="section-title" text="Active dialogs" />
                <ListView fx:id="dialogsList" prefHeight="320.0" VBox.vgrow="ALWAYS" />
                <Label styleClass="section-title" text="Online users" />
                <ListView fx:id="onlineList" prefHeight="260.0" VBox.vgrow="ALWAYS" />
            </VBox>
        </HBox>
    </center>
</BorderPane>
